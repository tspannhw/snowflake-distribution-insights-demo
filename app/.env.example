# ── Snowflake connection name (snow CLI profile) ──────────────────────────────
# Used by manage.sh when SNOWFLAKE_CONNECTION env var is not set.
# Must match a [section] in ~/.snowflake/connections.toml
SNOWFLAKE_CONNECTION=your_connection

# ── Snowflake ─────────────────────────────────────────────────────────────────
# Your Snowflake account identifier (e.g. myorg-myaccount or xy12345)
SNOWFLAKE_ACCOUNT=your_account_identifier

# Snowflake user with INSERT on ADVISOR_EVENTS_RAW
SNOWFLAKE_USER=your_snowflake_user

# Path to RSA private key (PEM/PKCS8 format, unencrypted)
# Generate with: openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out ~/.snowflake/keys/rsa_key.p8 -nocrypt
SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/keys/snowflake_private_key.p8

# SSv2-specific key — generate once with:
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out app/ssv2_rsa_key.p8 -nocrypt
# Then register with: ALTER USER <user> SET RSA_PUBLIC_KEY_2='<public_key_body>'
# This key is used only by the SSv2 consumer (registered as RSA_PUBLIC_KEY_2).
SSV2_PRIVATE_KEY_PATH=ssv2_rsa_key.p8

SNOWFLAKE_ROLE=SALES_ENGINEER
SNOWFLAKE_WAREHOUSE=INGEST
SNOWFLAKE_DATABASE=ANALYTICS_DEV_DB
SNOWFLAKE_SCHEMA=STAGING
SNOWFLAKE_TABLE=ADVISOR_EVENTS_RAW

# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_HOST=129.121.99.18
MQTT_PORT=1883
MQTT_TOPIC=distribution/advisor_events
MQTT_CLIENT_ID_PRODUCER=acme-dist-producer
MQTT_CLIENT_ID_CONSUMER=acme-dist-consumer
MQTT_KEEPALIVE=60

# Set to true if your broker requires authentication
MQTT_USE_AUTH=true
MQTT_USERNAME=myuser
# NEVER commit real passwords — fill this in your local .env only
MQTT_PASSWORD=your_mqtt_password_here

MQTT_QOS=1

# ── Producer behaviour ────────────────────────────────────────────────────────
# How often to publish (seconds)
PRODUCER_INTERVAL_SECONDS=5
# How long to run (minutes)
PRODUCER_DURATION_MINUTES=10
